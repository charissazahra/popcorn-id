# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# PEP 582; used by e.g. github.com/David-OConnor/pyflow
__pypackages__/
.pdm-python

# Virtual environment
venv/
env/
.venv/

# Environment variable files
.env
.env.*

# Distribution / packaging
build/
dist/
*.egg-info/

# Logs and database files
*.log
*.sqlite3
*.db

# Unit test / coverage reports
htmlcov/
.coverage
.tox/
.nox/
.pytest_cache/
.cache/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# Jupyter Notebooks (if used)
.ipynb_checkpoints/

# mypy
.mypy_cache/

# pyre
.pyre/

# PyInstaller
*.spec

# Poetry
poetry.lock

# FastAPI specific (if you use uvicorn reload file watching)
reload.db

# Pydantic compiled schema cache
__pydantic__/

# Docker
*.pid
*.tar
*.bak

# Misc
.DS_Store
Thumbs.db
